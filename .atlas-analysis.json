  "keyFeatures": [
    "Dual-section product catalog (Vape & 420) with filtering, search, and detailed product pages",
    "Persistent shopping cart with stock validation and WhatsApp + Mercado Pago checkout",
    "Full customer authentication with profiles, order history, and address management",
    "4-tier loyalty program (Bronze → Silver → Gold → Platinum) with points earn/burn",
    "Integrated admin panel with dashboard, product/category/order/customer/coupon management",
    "AI-powered edge functions via Google Gemini for inventory predictions, dashboard insights, and product copy",
    "PWA (Progressive Web App) with offline support, dark/light theme, and haptic feedback",
    "Real-time monitoring via Sentry and GA4 e-commerce event tracking"
  ],
  "publicApiSurface": [
    "getProducts(options?): Promise<Product[]>",
    "getFeaturedProducts(section?): Promise<Product[]>",
    "getProductBySlug(slug, section): Promise<Product | null>",
    "createOrder(data): Promise<OrderRecord>",
    "getCustomerOrders(customerId): Promise<OrderRecord[]>",
    "signUp(email, password, fullName, phone?): Promise<AuthResponse>",
    "signIn(email, password): Promise<AuthResponse>",
    "validateCoupon(code): Promise<Coupon | null>",
    "getDashboardStats(startDate?, endDate?): Promise<DashboardStats>",
    "useProducts(options?): UseQueryResult",
    "useCreateOrder(): UseMutationResult",
    "useSearch(query): UseQueryResult",
    "useLoyalty(): UseQueryResult",
    "CartStore: { items, addItem, removeItem, updateQuantity, clearCart }",
    "Edge Function: inventory-oracle",
    "Edge Function: dashboard-intelligence",
    "Edge Function: customer-intelligence",
    "Edge Function: voice-intelligence",
    "Edge Function: product-intelligence"
  ]
